{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "Capability for the main window",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"opener:default",
		"fs:allow-exists",
		"fs:allow-read-text-file",
		"fs:allow-write-text-file",
		"fs:allow-mkdir",
		"fs:allow-remove",
		"fs:allow-appdata-read-recursive",
		"fs:allow-appdata-write-recursive"
	]
}
